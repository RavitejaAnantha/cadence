#!/usr/bin/env bash
# Cadence pre-commit gate. Deterministic correctness checks on every commit: style, intent, tests.
# Documentation is reconciled after merge by the docs workflow, not here.
set -uo pipefail
export PATH="$HOME/.local/bin:$PATH"
cd "$(git rev-parse --show-toplevel)" || exit 1
fail=0
emdash=$(printf '\xe2\x80\x94')

echo "[1/3] no em-dashes in staged text..."
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|md|toml|sh|txt)$' || true)
if [ -n "$staged" ] && grep -l "$emdash" $staged 2>/dev/null; then
  echo "  FAIL: em-dash found in the files above. Use commas, periods, or parentheses."
  fail=1
else
  echo "  ok"
fi

echo "[2/3] intent check..."
if uv run python -m tools.intent_check >/tmp/cadence_intent.log 2>&1; then
  echo "  ok"
else
  cat /tmp/cadence_intent.log
  echo "  FAIL: intent check"
  fail=1
fi

echo "[3/3] tests..."
if uv run pytest -q >/tmp/cadence_pytest.log 2>&1; then
  echo "  ok"
else
  tail -25 /tmp/cadence_pytest.log
  echo "  FAIL: tests"
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "pre-commit gate FAILED. Commit blocked."
  exit 1
fi
echo "pre-commit gate PASSED."
exit 0
